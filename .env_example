# ============================================
# Voice IoT Controller - Environment Variables
# ============================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env_example .env
# ============================================

# ── 마이크 디바이스 인덱스 ──────────────────────
# `python -m sounddevice` 로 확인 가능
MIC_DEVICE=11

# ── Picovoice (Porcupine 웨이크워드) ───────────
# https://console.picovoice.ai/ 에서 AccessKey 발급
PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here

# ── Database (MySQL) ───────────────────────────
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── LLM (Ollama) ──────────────────────────────
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=exaone3.5:latest
