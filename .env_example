# ============================================
# Voice IoT Controller - Environment Variables
# ============================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
#   cp .env_example .env
# ============================================

# ── 마이크 디바이스 인덱스 ──────────────────────
# `python -m sounddevice` 로 확인 가능
MIC_DEVICE=

# ── Picovoice (Porcupine 웨이크워드) ───────────
# https://console.picovoice.ai/ 에서 AccessKey 발급
PORCUPINE_ACCESS_KEY=

# ── Database (MySQL) ───────────────────────────
DB_HOST=localhost
DB_USER=
DB_PASSWORD=

# ── LLM (Ollama) ──────────────────────────────
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=exaone3.5:7.8b

# ── JWT 인증 키 (최초 실행 시 run_server.sh가 자동 생성) ──
# JWT_SECRET=

# ── ESP32 HMAC 서명 키 ───────────────────────
# ESP32 config.h의 ESP32_SECRET과 동일한 값 설정
# 생성: python -c "import secrets; print(secrets.token_hex(16))"
ESP32_SECRET=

# ── SmartGate 제스처 인증 시퀀스 (선택) ─────────
# SMARTGATE_SEQUENCE=1,0,3

# ── ESP32-CAM UDP 허용 IP (선택) ────────────────
# CAM_ALLOWED_IPS=192.168.0.xx

# ── YouTube 중계 서버 (BT Speaker) ──────────────
# 중계 서버 포트 (기본: 8080)
RELAY_PORT=8080
# 접근 허용 IP (ESP32 WiFi IP, 콤마 구분)
# RELAY_ALLOWED_IPS=192.168.0.xx
# ESP32 BT 스피커 웹서버 URL (시리얼 모니터에서 IP 확인)
# BT_SPEAKER_URL=http://192.168.0.xx
